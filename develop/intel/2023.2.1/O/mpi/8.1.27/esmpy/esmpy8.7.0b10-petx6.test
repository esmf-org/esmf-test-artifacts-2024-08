        # elif create_rh == False:
        #     crh = ct.POINTER(ct.c_int(2))
    
        rc = _ESMF.ESMC_FieldRegridStoreFile(srcField.struct.ptr,
                                         dstField.struct.ptr,
                                         b_filename,
                                         srcMaskValues_i,
                                         dstMaskValues_i,
                                         ct.byref(routehandle),
                                         regridmethod,
                                         polemethod,
